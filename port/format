template <typename Context, typename... Args>
class format_arg_store {
private:
  static const size_t num_args = sizeof...(Args);
  static const size_t num_named_args = count_named_args<Args...>();
  static const bool is_packed = num_args <= max_packed_args;

  using value_type = conditional_t<is_packed, value<Context>, basic_format_arg<Context>>;

  arg_data<value_type, typename Context::char_type, num_args, num_named_args> data_;

  friend class basic_format_args<Context>;

  static constexpr unsigned long long desc = (is_packed ? encode_types<Context, Args...>()
                                                        : is_unpacked_bit | num_args) |
    (num_named_args != 0 ? static_cast<unsigned long long>(has_named_args_bit) : 0);

public:
  constexpr inline __attribute__((always_inline)) format_arg_store(const Args&... args)
    : data_{ make_arg<is_packed, Context, mapped_type_constant<Args, Context>::value>(args)... } {
    init_named_args(data_.named_args(), 0, 0, args...);
  }
};

