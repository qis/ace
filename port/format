template <typename T>
constexpr int count_digits_fallback(T n) {
  int count = 1;
  for (;;) {
    if (n < 10)
      return count;
    if (n < 100)
      return count + 1;
    if (n < 1000)
      return count + 2;
    if (n < 10000)
      return count + 3;
    n /= 10000u;
    count += 4;
  }
}
constexpr inline int count_digits(__uint128_t n) {
  return count_digits_fallback(n);
}

constexpr inline int count_digits(uint64_t n) {
  if (is_constant_evaluated()) {
    return count_digits_fallback(n);
  }
#ifdef FMT_BUILTIN_CLZLL
  auto t = bsr2log10(FMT_BUILTIN_CLZLL(n | 1) ^ 63);
  constexpr const uint64_t zero_or_powers_of_10[] = { 0, 0, FMT_POWERS_OF_10(1U), FMT_POWERS_OF_10(1000000000ULL),
    10000000000000000000ULL };
  return t - (n < zero_or_powers_of_10[t]);
#else
  return count_digits_fallback(n);
#endif
}

template <int BITS, typename UInt>
constexpr int count_digits(UInt n) {
#ifdef FMT_BUILTIN_CLZ
  if (num_bits<UInt>() == 32)
    return (FMT_BUILTIN_CLZ(static_cast<uint32_t>(n) | 1) ^ 31) / BITS + 1;
#endif
  int num_digits = 0;
  do {
    ++num_digits;
  } while ((n >>= BITS) != 0);
  return num_digits;
}

