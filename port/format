template <typename Char = char>
class dynamic_formatter {
private:
  struct null_handler : error_handler {
    void on_align(align_t) {
    }
    void on_sign(sign_t) {
    }
    void on_hash() {
    }
  };

public:
  template <typename ParseContext>
  constexpr auto parse(ParseContext& ctx) -> decltype(ctx.begin()) {
    format_str_ = ctx.begin();
    dynamic_specs_handler<ParseContext> handler(specs_, ctx);
    return parse_format_specs(ctx.begin(), ctx.end(), handler);
  }

  template <typename T, typename FormatContext>
  auto format(const T& val, FormatContext& ctx) -> decltype(ctx.out()) {
    handle_specs(ctx);
    specs_checker<null_handler> checker(null_handler(), mapped_type_constant<T, FormatContext>::value);
    checker.on_align(specs_.align);
    if (specs_.sign != sign::none)
      checker.on_sign(specs_.sign);
    if (specs_.alt)
      checker.on_hash();
    if (specs_.precision >= 0)
      checker.end_precision();
    return write<Char>(ctx.out(), val, specs_);
  }

private:
  template <typename Context>
  void handle_specs(Context& ctx) {
    handle_dynamic_spec<width_checker>(specs_.width, specs_.width_ref, ctx);
    handle_dynamic_spec<precision_checker>(specs_.precision, specs_.precision_ref, ctx);
  }

  dynamic_format_specs<Char> specs_;
  const Char* format_str_;
};

