template <typename T, typename Char>
struct formatter<T, Char, enable_if_t<type_constant<T, Char>::value != type::custom_type>> {
private:
  dynamic_format_specs<Char> specs_;

public:
  template <typename ParseContext>
  constexpr auto parse(ParseContext& ctx) -> decltype(ctx.begin()) {
    auto begin = ctx.begin(), end = ctx.end();
    if (begin == end)
      return begin;
    using handler_type = dynamic_specs_handler<ParseContext>;
    auto type = type_constant<T, Char>::value;
    auto checker = specs_checker<handler_type>(handler_type(specs_, ctx), type);
    auto it = parse_format_specs(begin, end, checker);
    auto eh = ctx.error_handler();
    switch (type) {
    case type::none_type:
      _LIBCPP_ASSERT(false, "invalid argument type");
      break;
    case type::bool_type:
      if (!specs_.type || specs_.type == 's')
        break;
      [[fallthrough]];
    case type::int_type:
    case type::uint_type:
    case type::long_long_type:
    case type::ulong_long_type:
    case type::int128_type:
    case type::uint128_type:
      check_int_type_spec(specs_.type, eh);
      break;
    case type::char_type:
      check_char_specs(specs_, eh);
      break;
    case type::float_type:
      parse_float_type_spec(specs_, eh);
      break;
    case type::double_type:
      parse_float_type_spec(specs_, eh);
      break;
    case type::long_double_type:
      parse_float_type_spec(specs_, eh);
      break;
    case type::cstring_type:
      check_cstring_type_spec(specs_.type, eh);
      break;
    case type::string_type:
      check_string_type_spec(specs_.type, eh);
      break;
    case type::pointer_type:
      check_pointer_type_spec(specs_.type, eh);
      break;
    case type::custom_type:
      break;
    }
    return it;
  }

  template <typename FormatContext>
  constexpr auto format(const T& val, FormatContext& ctx) const -> decltype(ctx.out());
};

