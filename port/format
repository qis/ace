template <typename Char, typename OutputIt>
OutputIt write_nonfinite(OutputIt out, bool isinf, const basic_format_specs<Char>& specs, const float_specs& fspecs) {
  auto str = isinf ? (fspecs.upper ? "INF" : "inf") : (fspecs.upper ? "NAN" : "nan");
  constexpr size_t str_size = 3;
  auto sign = fspecs.sign;
  auto size = str_size + (static_cast<int>(sign) ? 1 : 0);
  return write_padded(out, specs, size, [=](reserve_iterator<OutputIt> it) {
    if (static_cast<int>(sign))
      *it++ = static_cast<Char>(data::signs[static_cast<unsigned>(sign)]);
    return copy_str<Char>(str, str + str_size, it);
  });
}

