  template <typename T, FMT_ENABLE_IF(is_char<T>::value)>
  constexpr inline __attribute__((always_inline)) auto map(T val) -> char_type {
    static_assert(::std::is_same<T, char>::value || ::std::is_same<T, char_type>::value,
      "mixing character types is disallowed");
    return val;
  }

  constexpr inline __attribute__((always_inline)) auto map(float val) -> float {
    return val;
  }
  constexpr inline __attribute__((always_inline)) auto map(double val) -> double {
    return val;
  }
  constexpr inline __attribute__((always_inline)) auto map(long double val) -> long double {
