template <typename Char, typename OutputIt, typename T>
auto write(OutputIt out, const T& value) ->
  typename ::std::enable_if<mapped_type_constant<T, basic_format_context<OutputIt, Char>>::value == type::custom_type,
    OutputIt>::type {
  using context_type = basic_format_context<OutputIt, Char>;
  using formatter_type = conditional_t<has_formatter<T, context_type>::value,
    typename context_type::template formatter_type<T>, fallback_formatter<T, Char>>;
