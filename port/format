    _LIBCPP_ASSERT(k >= float_info<double>::min_k && k <= float_info<double>::max_k, "k is out of range");

    static constexpr const uint128_wrapper pow10_significands[] = { { 0xff77b1fcbebcdc4f, 0x25e8e89c13bb0f7b },
